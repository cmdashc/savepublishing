{
  "manifest_version": 3,
  "name": "Quotelink (working title)",
  "version": "0.1.0",
  "description": "Click a sentence in any article and share it with attribution. The 2012 SavePublishing bookmarklet, reborn.",
  "action": {
    "default_title": "Find shareable sentences",
    "default_icon": { "128": "icons/icon-128.png" }
  },
  "icons": { "128": "icons/icon-128.png" },
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"],
    "type": "module"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "browser_specific_settings": {
    "gecko": { "id": "quotelink@savepublishing", "strict_min_version": "109.0" }
  }
}
